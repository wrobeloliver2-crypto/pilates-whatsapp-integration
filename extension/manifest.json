{
  "manifest_version": 3,
  "name": "Pilates Company – Lead-Sidebar für WhatsApp",
  "description": "Zeigt zur Telefonnummer des aktiven WhatsApp-Chats die passende Karte aus dem Lead-Dashboard und hält immer nur einen WhatsApp-Web-Tab offen.",
  "version": "1.3.0",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://pilatesleaddashboard.netlify.app/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://pilatesleaddashboard.netlify.app/*", "https://web.whatsapp.com/*"]
}
